# Cache hashed JS/CSS bundles forever (Vite adds content hashes to filenames)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Cache images for 1 year (they change infrequently; bust by renaming)
/asset/image/*
  Cache-Control: public, max-age=31536000, immutable

# Cache fonts forever
/Webfonts-Bamberg\ Serial/*
  Cache-Control: public, max-age=31536000, immutable

# Markdown content files — cache for 1 hour, allow stale while revalidating
/*.md
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

/photo/*.md
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

/note/atomic/*.md
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

/note/book/*.md
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

/note/clipping/*.md
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

/writing/*.md
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

# HTML — always revalidate
/*
  Cache-Control: public, max-age=0, must-revalidate
  X-Content-Type-Options: nosniff
